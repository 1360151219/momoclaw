# ============================================
# MiniClaw AI Assistant Configuration
# ============================================

# --------------------------------------------
# API Keys (至少填一个)
# --------------------------------------------

# Anthropic Claude API Key
ANTHROPIC_API_KEY=

# OpenAI Compatible API Key (Kimi, DeepSeek, etc.)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.moonshot.cn/v1  # Kimi示例

# --------------------------------------------
# Default Settings
# --------------------------------------------

# 默认模型 (支持anthropic/前缀或openai/前缀)
# Claude模型: anthropic/claude-sonnet-4-6, anthropic/claude-opus-4-6
# OpenAI兼容: openai/gpt-4, openai/kimi-latest 等
MODEL=anthropic/claude-sonnet-4-6

# 最大token数
MAX_TOKENS=4096

# 工作目录路径 (容器挂载的目录)
WORKSPACE_DIR=./workspace

# 容器超时时间 (毫秒)
CONTAINER_TIMEOUT=300000

# 数据库路径
DB_PATH=./data/miniclaw.db

# 默认System Prompt (可选，留空使用内置默认)
DEFAULT_SYSTEM_PROMPT=
