# ============================================
# MiniClaw AI Assistant Configuration
# ============================================

# --------------------------------------------
# API Keys (至少填一个)
# --------------------------------------------

# Anthropic Claude API Key (或 Kimi Code Plan)
ANTHROPIC_API_KEY=
# Kimi Code Plan Anthropic 兼容地址 (可选)
ANTHROPIC_BASE_URL=https://api.moonshot.cn/anthropic

# OpenAI Compatible API Key (Kimi, DeepSeek, etc.)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.moonshot.cn/v1

# --------------------------------------------
# Default Settings
# --------------------------------------------

# 默认模型 (支持anthropic/前缀或openai/前缀)
# Kimi Code Plan: anthropic/claude-opus-4-20250514
# Kimi 开放平台: openai/moonshot-v1-8k
MODEL=anthropic/claude-opus-4-20250514

# 最大token数
MAX_TOKENS=4096

# 工作目录路径 (容器挂载的目录)
WORKSPACE_DIR=./workspace

# 容器超时时间 (毫秒)
CONTAINER_TIMEOUT=300000

# 数据库路径
DB_PATH=./data/miniclaw.db

# 默认System Prompt (可选，留空使用内置默认)
DEFAULT_SYSTEM_PROMPT=

# Context7 API Key
CONTEXT7_API_KEY=

# GitHub Personal Access Token
GITHUB_TOKEN=

# --------------------------------------------
# Feishu (Lark) Bot Configuration
# --------------------------------------------

# 飞书机器人 App ID (从飞书开放平台获取)
FEISHU_APP_ID=

# 飞书机器人 App Secret
FEISHU_APP_SECRET=

# 飞书域名 (feishu 或 lark, 默认 feishu)
# FEISHU_DOMAIN=feishu

# 加密密钥 (可选，用于消息验证)
# FEISHU_ENCRYPT_KEY=

# 验证令牌 (可选)
# FEISHU_VERIFICATION_TOKEN=

# 自动回复群组 ID (逗号分隔，可选)
# 在这些群组中机器人会自动回复，不需要 @机器人
# FEISHU_AUTO_REPLY_GROUPS=

# 飞书模块日志级别 (debug, info, warn, error)
# FEISHU_LOG_LEVEL=info
